# Basic app identity
# Optional. If set, the app title displays ORG_NAME directly.
# If empty, the app title is "组织雷达".
ORG_NAME=

# Optional access code for web login.
# If empty, access control is disabled and visitors enter directly.
# If set, visitors must enter this code before accessing organization data.
ACCESS_CODE=

# Server
PORT=3001
WEB_PORT=5174

# Comma-separated hostnames allowed by Vite dev server when using reverse proxy.
# This does not create DNS or nginx rules. It only tells Vite which Host headers are allowed.
# Set it when you already proxy a domain to WEB_PORT.
# Example: VITE_ALLOWED_HOSTS=org-map.example.com
VITE_ALLOWED_HOSTS=

# Data path. Relative paths are resolved from the project root.
ORG_RADAR_DATA_DIR=./data

# Optional: override the SQLite database path directly.
# ORG_RADAR_DB_PATH=./data/organization_radar.sqlite
